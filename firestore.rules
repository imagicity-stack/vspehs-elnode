rules_version = '2';

// ─────────────────────────────────────────────────────────────
// El-Node — Firestore security rules
// ─────────────────────────────────────────────────────────────
// A user's role is resolved from (in order): a custom auth claim, their
// `appUsers/{uid}` document, or the Super Admin email allowlist below. Roles
// gate write access by area. Tighten further before production (e.g. per-class
// teacher scoping, and replace the email allowlist with custom claims for all).
// ─────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Emails permitted to act as Super Admin without a provisioned profile.
    // KEEP IN SYNC with the NEXT_PUBLIC_SUPERADMIN_EMAILS env var. This is the
    // bootstrap that lets a freshly-signed-in Google admin read/write before any
    // appUsers/{uid} document exists.
    function adminEmails() {
      return ["dewesh@eldenheights.org", "contact.vsp@eldenheights.org"];
    }
    // Managed admins added in-app (appConfig/superadmins). Guarded so a missing
    // doc never errors the rule.
    function managedAdmins() {
      return exists(/databases/$(database)/documents/appConfig/superadmins)
        ? get(/databases/$(database)/documents/appConfig/superadmins).data.emails
        : [];
    }
    function isAllowlistedAdmin() {
      return isSignedIn() && (
        request.auth.token.email in adminEmails()
        || request.auth.token.email in managedAdmins()
      );
    }

    function hasProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/appUsers/$(request.auth.uid));
    }

    // Role resolution order: custom claim (set by the server for parents) →
    // appUsers profile document → "anon". Guarded so a missing profile never
    // errors the rule.
    function role() {
      return !isSignedIn() ? "anon"
        : request.auth.token.role != null ? request.auth.token.role
        : hasProfile()
          ? get(/databases/$(database)/documents/appUsers/$(request.auth.uid)).data.role
          : "anon";
    }

    function isStaff() {
      return isAllowlistedAdmin() || role() in ["teacher", "accountant", "superadmin"];
    }

    function isAdmin() {
      return isAllowlistedAdmin() || role() == "superadmin";
    }

    function isFinance() {
      return isAllowlistedAdmin() || role() in ["accountant", "superadmin"];
    }

    // Throwaway collection used by the in-app diagnostics "write test".
    match /_diagnostics/{id} {
      allow read, write: if isSignedIn();
    }

    // App configuration — e.g. the managed Super Admin list. Any signed-in user
    // may read (login needs to check it); only admins may change it.
    match /appConfig/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // App user profiles
    match /appUsers/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isStaff());
      allow write: if isAdmin();
    }

    // Read-mostly directories: any signed-in user may read; staff may write.
    match /students/{id}   { allow read: if isSignedIn(); allow write: if isStaff(); }
    match /classes/{id}    { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /staff/{id}      { allow read: if isStaff();    allow write: if isAdmin(); }
    // Subject master list — any signed-in user may read; only admins manage it.
    match /subjects/{id}   { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Attendance, daily updates, homework, exams — teachers & admins write.
    match /attendance/{id}      { allow read: if isSignedIn(); allow write: if isStaff(); }
    match /staffAttendance/{id} { allow read: if isStaff();    allow write: if isStaff(); }
    match /dailyUpdates/{id}    { allow read: if isSignedIn(); allow write: if isStaff(); }
    match /homework/{id}        { allow read: if isSignedIn(); allow write: if isStaff(); }
    match /exams/{id}           { allow read: if isSignedIn(); allow write: if isStaff(); }
    match /examResults/{id}     { allow read: if isSignedIn(); allow write: if isStaff(); }

    // Finance — accountants & admins write.
    match /feeHeads/{id}    { allow read: if isSignedIn(); allow write: if isFinance(); }
    match /invoices/{id}    { allow read: if isSignedIn(); allow write: if isFinance(); }
    match /payments/{id}    { allow read: if isSignedIn(); allow write: if isFinance(); }
    match /concessions/{id} { allow read: if isSignedIn(); allow write: if isFinance(); }

    // Communications & calendar
    match /circulars/{id} { allow read: if isSignedIn(); allow write: if isStaff(); }
    match /events/{id}    { allow read: if isSignedIn(); allow write: if isStaff(); }

    // Staff self-service
    match /leaveRequests/{id} { allow read: if isStaff(); allow write: if isStaff(); }
    match /taskItems/{id}     { allow read: if isStaff(); allow write: if isStaff(); }
  }
}
