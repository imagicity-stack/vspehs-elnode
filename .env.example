# ─────────────────────────────────────────────────────────────
# El-Node — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in your Firebase values.
#
# If these are left blank, El-Node runs in DEMO MODE using a built-in
# seeded dataset (no backend required) — perfect for previews on Vercel.
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firestore database id. Leave blank (or "(default)") to use the project's
# default database; set this to use a named/secondary Firestore database.
NEXT_PUBLIC_FIREBASE_DATABASE_ID=

# Domain used to synthesise parent login (7-digit number -> email).
# Parents sign in with a 7-digit admission number; internally this maps to
# <number>@<NEXT_PUBLIC_PARENT_EMAIL_DOMAIN>.
NEXT_PUBLIC_PARENT_EMAIL_DOMAIN=parents.el-node.app

# Initial password assigned to every newly-created login (parents & staff).
# Users change it from "Change password" in their portal.
NEXT_PUBLIC_DEFAULT_PASSWORD=password123

# ─────────────────────────────────────────────────────────────
# Super Admin — Google sign-in allowlist
# ─────────────────────────────────────────────────────────────
# Comma-separated list of Google emails permitted to sign in as Super Admin.
NEXT_PUBLIC_SUPERADMIN_EMAILS=dewesh@eldenheights.org

# ─────────────────────────────────────────────────────────────
# Firebase Admin SDK (SERVER-ONLY) — used to auto-create a parent's
# Firebase Auth login when a student is added. Get these from a Service
# Account key (Firebase console > Project settings > Service accounts).
# Never prefix with NEXT_PUBLIC. Keep the quotes around the private key;
# literal "\n" sequences inside it are handled automatically.
# ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────
# Razorpay — online fee payments (Parent portal)
# ─────────────────────────────────────────────────────────────
# Key ID is public (used in the browser to open Checkout).
# Key Secret is SERVER-ONLY — never prefix it with NEXT_PUBLIC.
# If these are blank, the pay flow falls back to the simulated demo payment.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional: only needed if you wire up Razorpay webhooks.
RAZORPAY_WEBHOOK_SECRET=
