rules_version = '2';

// ─────────────────────────────────────────────────────────────
// El-Node — Firebase Storage security rules
// ─────────────────────────────────────────────────────────────
// Student photos (used on ID cards and profiles). Any signed-in user may read;
// only staff / admins may upload. Keep adminEmails() in sync with
// firestore.rules and NEXT_PUBLIC_SUPERADMIN_EMAILS.
// Deploy with: firebase deploy --only storage
// ─────────────────────────────────────────────────────────────

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }
    function isAdminEmail() {
      return isSignedIn() && request.auth.token.email in [
        "dewesh@eldenheights.org",
        "contact.vsp@eldenheights.org"
      ];
    }
    function isStaff() {
      return isAdminEmail()
        || (isSignedIn() && request.auth.token.role in ["teacher", "accountant", "superadmin"]);
    }

    match /student-photos/{file} {
      allow read: if isSignedIn();
      allow write: if isStaff()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }
  }
}
